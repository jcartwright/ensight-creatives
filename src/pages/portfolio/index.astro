---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { projects } from '../../data/projects';
import { site } from '../../data/site';
---

<BaseLayout
  title="Portfolio"
  description={`Selected aerial projects from Ensight Creatives: brand films, events, real estate, and land in ${site.region} and ${site.regionBroad}.`}
>
  <section class="atmosphere">
    <div class="mx-auto max-w-6xl px-5 py-16 md:px-8 md:py-24">
      <p class="text-sm font-medium tracking-[0.14em] text-skyline uppercase">Portfolio</p>
      <h1 class="font-display mt-3 max-w-2xl text-4xl font-bold tracking-tight text-ink md:text-5xl">
        Selected work
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-ink-soft">
        Brand films, events, historic sites, and land projects around Dallas/Fort Worth and North Central Texas.
      </p>

      <div class="mt-14 grid gap-14 md:grid-cols-2">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>

      <div class="mt-20 border-t border-line pt-12">
        <h2 class="font-display text-2xl font-semibold text-ink">Need something similar?</h2>
        <p class="mt-3 max-w-xl text-ink-soft">
          Tell us about the project and timeline. We’ll reply by email.
        </p>
        <a
          href="/contact/"
          class="mt-6 inline-flex bg-horizon px-6 py-3 font-medium text-cloud transition hover:bg-horizon-deep"
        >
          Request info
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
