---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { projects } from '../../data/projects';
import { site } from '../../data/site';
---

<BaseLayout
  title="Portfolio"
  description={`Aerial imaging portfolio from Ensight Creatives — construction, commercial real estate, and brand media across ${site.region} and ${site.regionBroad}.`}
>
  <section class="atmosphere">
    <div class="mx-auto max-w-6xl px-5 py-16 md:px-8 md:py-24">
      <p class="text-sm font-medium tracking-[0.2em] text-skyline uppercase">Portfolio</p>
      <h1 class="font-display mt-3 max-w-2xl text-4xl font-bold tracking-tight text-ink md:text-5xl">
        Work from above
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-ink-soft">
        Selected aerial projects for construction, commercial real estate, and brand storytelling in Dallas/Fort Worth.
      </p>

      <div class="mt-14 grid gap-14 md:grid-cols-2">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>

      <div class="mt-20 border-t border-line pt-12">
        <h2 class="font-display text-2xl font-semibold text-ink">Have a site that needs this?</h2>
        <p class="mt-3 max-w-xl text-ink-soft">
          Share your project details and timeline—we’ll respond by email (and text, once notifications are connected).
        </p>
        <a
          href="/contact/"
          class="mt-6 inline-flex bg-horizon px-6 py-3 font-medium text-cloud transition hover:bg-horizon-deep"
        >
          Request info
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
