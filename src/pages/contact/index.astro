---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactForm from '../../components/ContactForm.astro';
import { site } from '../../data/site';
---

<BaseLayout
  title="Contact"
  description={`Request aerial imaging info from Ensight Creatives in ${site.region}. Construction, CRE, and brand media across ${site.regionBroad}.`}
>
  <section class="atmosphere">
    <div class="mx-auto grid max-w-6xl gap-12 px-5 py-16 md:grid-cols-[1fr_1.2fr] md:gap-16 md:px-8 md:py-24">
      <div>
        <p class="text-sm font-medium tracking-[0.2em] text-skyline uppercase">Contact</p>
        <h1 class="font-display mt-3 text-4xl font-bold tracking-tight text-ink md:text-5xl">
          Request info
        </h1>
        <p class="mt-4 text-lg text-ink-soft">
          Tell us about your project in Dallas/Fort Worth or elsewhere in North Central Texas. We’ll get back to you by
          email.
        </p>
        <ul class="mt-8 space-y-3 text-sm text-ink-soft">
          <li class="flex gap-2">
            <span class="text-flare" aria-hidden="true">▸</span>
            Part 107 certified operations
          </li>
          <li class="flex gap-2">
            <span class="text-flare" aria-hidden="true">▸</span>
            Construction, CRE, and brand media
          </li>
          <li class="flex gap-2">
            <span class="text-flare" aria-hidden="true">▸</span>
            Serving {site.regionLabel}
          </li>
        </ul>
      </div>

      <div>
        <ContactForm />
      </div>
    </div>
  </section>
</BaseLayout>
