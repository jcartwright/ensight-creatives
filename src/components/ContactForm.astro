---
const formId = import.meta.env.PUBLIC_FORMSPREE_FORM_ID ?? '';
const configured = Boolean(formId);
---

{
  configured ? (
    <form id="contact-form" class="space-y-5" novalidate>
      <div class="grid gap-5 md:grid-cols-2">
        <label class="block">
          <span class="mb-1.5 block text-sm font-medium text-ink">Name</span>
          <input
            type="text"
            name="name"
            required
            autocomplete="name"
            class="w-full border border-line bg-cloud px-3 py-2.5 outline-none transition focus:border-skyline"
          />
        </label>
        <label class="block">
          <span class="mb-1.5 block text-sm font-medium text-ink">Email</span>
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            class="w-full border border-line bg-cloud px-3 py-2.5 outline-none transition focus:border-skyline"
          />
        </label>
      </div>

      <label class="block">
        <span class="mb-1.5 block text-sm font-medium text-ink">
          Company <span class="font-normal text-ink-soft">(optional)</span>
        </span>
        <input
          type="text"
          name="company"
          autocomplete="organization"
          class="w-full border border-line bg-cloud px-3 py-2.5 outline-none transition focus:border-skyline"
        />
      </label>

      <label class="block">
        <span class="mb-1.5 block text-sm font-medium text-ink">Project type</span>
        <select
          name="project_type"
          required
          class="w-full border border-line bg-cloud px-3 py-2.5 outline-none transition focus:border-skyline"
        >
          <option value="" disabled selected>
            Select one
          </option>
          <option value="brand">Brand or events</option>
          <option value="real_estate">Real estate or land</option>
          <option value="construction">Construction progress</option>
          <option value="website">Custom website or content site</option>
          <option value="other">Other</option>
        </select>
      </label>

      <label class="block">
        <span class="mb-1.5 block text-sm font-medium text-ink">Message</span>
        <textarea
          name="message"
          required
          rows="5"
          class="w-full resize-y border border-line bg-cloud px-3 py-2.5 outline-none transition focus:border-skyline"
        />
      </label>

      <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />

      <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
        <button
          type="submit"
          id="contact-submit"
          class="inline-flex items-center justify-center bg-horizon px-6 py-3 font-medium text-cloud transition hover:bg-horizon-deep disabled:cursor-not-allowed disabled:opacity-60"
        >
          Send request
        </button>
        <p id="contact-status" class="text-sm text-ink-soft" role="status" aria-live="polite" />
      </div>
    </form>
  ) : (
    <div class="border border-line bg-mist/60 px-5 py-6">
      <p class="font-medium text-ink">Contact form not configured yet</p>
      <p class="mt-2 text-sm text-ink-soft">
        Set <code class="text-horizon">PUBLIC_FORMSPREE_FORM_ID</code> in your environment (see
        <code class="text-horizon">.env.example</code> and the README) to enable submissions.
      </p>
    </div>
  )
}

{
  configured && (
    <script define:vars={{ formId }}>
      const form = document.getElementById('contact-form');
      const status = document.getElementById('contact-status');
      const submit = document.getElementById('contact-submit');

      if (form instanceof HTMLFormElement && status && submit instanceof HTMLButtonElement) {
        form.addEventListener('submit', async (event) => {
          event.preventDefault();
          status.textContent = 'Sending…';
          submit.disabled = true;

          try {
            const data = new FormData(form);
            const response = await fetch(`https://formspree.io/f/${formId}`, {
              method: 'POST',
              body: data,
              headers: { Accept: 'application/json' },
            });

            if (response.ok) {
              form.reset();
              status.textContent = 'Thanks. Your request was sent. We will be in touch soon.';
            } else {
              status.textContent = 'Something went wrong. Please try again in a moment.';
            }
          } catch {
            status.textContent = 'Unable to send right now. Please try again shortly.';
          } finally {
            submit.disabled = false;
          }
        });
      }
    </script>
  )
}
