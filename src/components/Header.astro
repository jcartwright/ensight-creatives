---
import { site } from '../data/site';
import LogoMark from './LogoMark.astro';

interface Props {
  variant?: 'overlay' | 'solid';
}

const { variant = 'solid' } = Astro.props;
const pathname = Astro.url.pathname;
const links = [
  { href: '/portfolio/', label: 'Portfolio' },
  { href: '/contact/', label: 'Contact' },
];

function isActive(href: string) {
  return pathname === href || pathname === href.replace(/\/$/, '');
}

const overlay = variant === 'overlay';
---

<header class:list={[overlay ? 'absolute inset-x-0 top-0 z-40' : 'relative z-40 border-b border-line bg-cloud/90 backdrop-blur-sm']}>
  <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-5 md:px-8">
    <a
      href="/"
      aria-label={site.name}
      class:list={[
        'group flex items-center gap-3 no-underline',
        overlay ? 'text-cloud' : 'text-ink',
      ]}
    >
      <LogoMark
        class={`h-9 w-9 shrink-0 transition ${overlay ? 'text-horizon/80 group-hover:text-horizon' : 'text-horizon group-hover:text-horizon-deep'}`}
      />
      <span class="leading-tight">
        <span
          class:list={[
            'font-display block text-sm font-semibold tracking-tight uppercase md:text-[0.95rem]',
            overlay ? 'text-cloud' : 'text-ink',
          ]}
        >
          EN<span class:list={[overlay ? 'text-flare' : 'text-horizon']} aria-hidden="true">/</span>SIGHT
        </span>
        <span
          class:list={[
            'block text-[0.65rem] font-medium tracking-[0.16em] uppercase',
            overlay ? 'text-cloud/70' : 'text-ink-soft/70',
          ]}
        >
          Creatives
        </span>
      </span>
    </a>

    <nav class="flex items-center gap-0.5 text-sm sm:gap-1 md:gap-2" aria-label="Primary">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              'rounded-md px-2 py-2 transition-colors sm:px-3',
              link.href === '/contact/' && 'hidden sm:inline-flex',
              overlay
                ? isActive(link.href)
                  ? 'font-semibold text-cloud'
                  : 'text-cloud/80 hover:text-cloud'
                : isActive(link.href)
                  ? 'font-semibold text-horizon'
                  : 'text-ink-soft hover:text-horizon',
            ]}
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="/contact/"
        class:list={[
          'ml-1 rounded-md px-3 py-2 font-medium transition sm:px-3.5 md:ml-2',
          overlay
            ? 'bg-cloud/15 text-cloud ring-1 ring-cloud/35 hover:bg-cloud/25'
            : 'bg-horizon text-cloud hover:bg-horizon-deep',
        ]}
      >
        Request info
      </a>
    </nav>
  </div>
</header>
